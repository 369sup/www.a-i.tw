{
  "name": "www.a-i.tw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "turbo run dev --filter=@a-i/web",
    "build": "turbo run build",
    "start": "pnpm --filter @a-i/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "pnpm format:check && turbo run check test",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter @a-i/e2e test:e2e",
    "generate:context": "node .agents/skills/scaffold-bounded-context/scripts/generate.mjs",
    "generate:subdomain": "node .agents/skills/scaffold-bounded-context/scripts/generate-subdomain.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "arch:imports": "node scripts/architecture/check-import-graph.mjs",
    "arch:manifests": "node scripts/architecture/check-context-manifests.mjs",
    "arch:context-target": "node scripts/architecture/check-context-target-topology.mjs",
    "arch:topology": "node scripts/architecture/check-repository-topology.mjs",
    "arch:exports": "node scripts/architecture/check-package-exports.mjs",
    "arch:workspaces": "node scripts/architecture/check-workspace-dependencies.mjs",
    "arch:cross-context": "node scripts/architecture/check-cross-context-imports.mjs",
    "arch:rules:test": "pnpm --filter @a-i/architecture-tests test",
    "arch:check": "pnpm arch:topology && pnpm arch:manifests && pnpm arch:context-target && pnpm arch:exports && pnpm arch:workspaces && pnpm arch:cross-context && pnpm arch:imports && pnpm arch:rules:test",
    "turbo": "turbo run",
    "semgrep": "mkdir -p /tmp/www-ai-semgrep-home && env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY HOME=/tmp/www-ai-semgrep-home semgrep scan --config .semgrep/ci.yml --config .semgrep/architecture.yml --exclude '**/.next/**' --exclude '**/.source/**' --error --metrics=off apps packages scripts",
    "docs:check": "node scripts/validation/check-docs.mjs && node scripts/validation/check-architecture-documents.mjs && node scripts/validation/check-links.mjs && node scripts/validation/check-workspaces.mjs",
    "docs:architecture": "node scripts/validation/check-architecture-documents.mjs",
    "release:check": "node scripts/validation/release-check.mjs",
    "ci": "bash scripts/validation/verify.sh release",
    "task:status": "bash scripts/validation/status.sh",
    "task:verify": "bash scripts/validation/verify.sh changed",
    "task:verify:runtime": "bash scripts/validation/verify.sh runtime",
    "task:verify:docs": "bash scripts/validation/verify.sh docs",
    "task:verify:all": "bash scripts/validation/verify.sh release",
    "task:release": "bash scripts/validation/verify.sh release"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "18.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "turbo": "^2.10.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  }
}
