{
  "name": "www.a-i.tw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev": "turbo run dev --filter=@a-i/web",
    "build": "turbo run build",
    "start": "pnpm --filter @a-i/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "pnpm format:check && turbo run check test",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "pnpm --filter @a-i/e2e test:e2e",
    "checkpoint:context": "node scripts/validation/codex-context-checkpoint/check-context.mjs",
    "generate:context": "node .agents/plugins/plugins/modules/skills/scaffold-bounded-context/scripts/generate.mjs",
    "migrate:context-topology": "node scripts/architecture/migrate-context-topology.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "arch:imports": "node scripts/architecture/check-import-graph.mjs",
    "arch:manifests": "node scripts/architecture/check-context-manifests.mjs",
    "arch:context-template": "node scripts/architecture/check-context-target-topology.mjs",
    "migrate:context-portfolio": "node scripts/architecture/migrate-context-portfolio.mjs",
    "arch:topology": "node scripts/architecture/check-repository-topology.mjs",
    "arch:exports": "node scripts/architecture/check-package-exports.mjs",
    "arch:workspaces": "node scripts/architecture/check-workspace-dependencies.mjs",
    "arch:cross-context": "node scripts/architecture/check-cross-context-imports.mjs",
    "arch:source": "node scripts/architecture/check-source-policies.mjs",
    "arch:rules:test": "pnpm --filter @a-i/architecture-tests test",
    "arch:check": "pnpm arch:topology && pnpm arch:manifests && pnpm arch:context-template && pnpm arch:exports && pnpm arch:workspaces && pnpm arch:cross-context && pnpm arch:source && pnpm arch:imports && pnpm arch:rules:test",
    "turbo": "turbo run",
    "semgrep": "node scripts/validation/run-semgrep.mjs",
    "docs:check": "node scripts/validation/check-docs.mjs && node scripts/validation/check-architecture-documents.mjs && node scripts/validation/check-links.mjs && node scripts/validation/check-workspaces.mjs",
    "docs:architecture": "node scripts/validation/check-architecture-documents.mjs",
    "release:check": "node scripts/validation/release-check.mjs",
    "ci": "node scripts/validation/verify.mjs release",
    "task:status": "node scripts/validation/status.mjs",
    "task:verify": "node scripts/validation/verify.mjs changed",
    "task:verify:runtime": "node scripts/validation/verify.mjs runtime",
    "task:verify:docs": "node scripts/validation/verify.mjs docs",
    "task:verify:all": "node scripts/validation/verify.mjs release",
    "task:release": "node scripts/validation/verify.mjs release"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "18.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "28.1.0",
    "prettier": "3.9.5",
    "turbo": "^2.10.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  }
}
