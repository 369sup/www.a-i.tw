{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": { "outputs": [] },
    "typecheck": { "outputs": [] },
    "check": { "dependsOn": ["lint", "typecheck"], "outputs": [] },
    "test": { "dependsOn": ["^test"], "outputs": [] },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": ["coverage/**"]
    },
    "dev": { "cache": false, "persistent": true }
  }
}
