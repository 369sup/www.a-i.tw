{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bounded Context Map",
  "type": "object",
  "required": ["version", "contexts"],
  "properties": {
    "version": { "const": 1 },
    "contexts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "context",
          "package",
          "domain",
          "subdomain",
          "owner",
          "relationships"
        ],
        "properties": {
          "context": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "package": { "type": "string", "pattern": "^@a-i/[a-z][a-z0-9-]*$" },
          "domain": { "type": "string", "minLength": 1 },
          "subdomain": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "enum": ["core", "supporting", "generic"] }
            }
          },
          "owner": { "type": "string", "minLength": 1 },
          "relationships": { "type": "array" }
        }
      }
    }
  }
}
