      "kind": "product",
      "lifecycle": "approved",
      "package": "@a-i/web",
      "domain": "Identity and Access",
      "subdomain": {
        "name": "identity-access",
        "type": "supporting"
      },
      "owner": "www.a-i.tw Product Team",
      "problem": "Authenticate a principal and maintain session attribution without deciding product authorization.",
