          "upstream": "identity-access",
          "pattern": "anti-corruption-layer",
          "contract": "PrincipalRefV1"
        },
        {
          "target": "repository",
          "upstream": "repository",
          "pattern": "anti-corruption-layer",
          "contract": "RepositoryCollaborationScopeV1, RepositoryParticipationDecisionV1"
