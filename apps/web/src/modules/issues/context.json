{
  "context": "issues",
  "kind": "product",
  "lifecycle": "approved",
  "package": "@a-i/web",
  "domain": "Issues",
  "subdomain": {
    "name": "issues",
    "type": "core"
  },
  "owner": "www.a-i.tw Product Team",
  "problem": "Track repository-scoped work with Issue identity, lifecycle, labels, assignment and collaboration relationships.",
  "firstUseCase": "Create, classify, assign and close an Issue after authoritative Repository participation approval.",
  "sourceOfTruth": [
    "Issue",
    "Label",
    "IssueComment",
    "Milestone",
    "IssueDependency"
  ],
  "runtimeEvidence": { "status": "current", "verifiedAt": "2026-07-12" },
  "relationships": [
    {
      "upstream": "identity-access",
      "downstream": "issues",
      "pattern": "open-host-service + published-language",
      "contract": "PrincipalRefV1",
      "consumerPort": "IssuePrincipal",
      "consumerAcl": "AppCompositionPrincipalMapper",
      "consistency": "synchronous",
      "failureMode": "deny-inactive-principal",
      "status": "current"
    },
    {
      "upstream": "repository",
      "downstream": "issues",
      "pattern": "open-host-service + published-language + anti-corruption-layer",
      "contract": "RepositoryParticipationApiV1",
      "consumerPort": "RepositoryParticipation",
      "consumerAcl": "RepositoryParticipationAdapter",
      "consistency": "synchronous",
      "failureMode": "deny-unavailable-or-forbidden-repository",
      "status": "current"
    }
  ]
}
