      "consumerPort": "PersonalAppOwnerDirectory",
      "consumerAcl": "PersonalAppOwnerDirectoryAdapter",
      "consistency": "synchronous",
      "failureMode": "reject-unavailable-or-inactive-personal-account-owner",
