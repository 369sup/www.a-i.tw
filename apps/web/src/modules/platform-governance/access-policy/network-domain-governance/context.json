      "failureMode": "reject-unavailable-enterprise",
      "status": "prototype"
    },
    {
      "upstream": "administrative-access-control",
      "downstream": "network-domain-governance",
      "pattern": "open-host-service + published-language + anti-corruption-layer",
      "contract": "AdministrativeAccessApiV1",
      "consumerPort": "NetworkDomainAdministration",
      "consumerAcl": "NetworkDomainAdministrationAdapter",
