      "consumerAcl": "AccountAuthorizationDirectoryAdapter",
      "consistency": "synchronous",
      "failureMode": "deny-unavailable-participation-facts",
      "status": "current"
    },
    {
      "upstream": "policy-governance",
      "downstream": "repository-governance",
      "pattern": "open-host-service + published-language + anti-corruption-layer",
      "contract": "RepositoryPolicyDecisionApiV1",
